{
  "credentials": [
    {
      "id": "jenkins-token",
      "type": "secretText",
      "description": "Jenkins API token",
      "secretEnv": "JENKINS_TOKEN"
    },
    {
      "id": "jenkins_token",
      "type": "secretText",
      "description": "Jenkins API token alternate ID",
      "secretEnv": "JENKINS_TOKEN_ALT"
    },
    {
      "id": "docker",
      "type": "usernamePassword",
      "description": "Docker registry credentials",
      "usernameEnv": "DOCKER_USERNAME",
      "passwordEnv": "DOCKER_PASSWORD"
    },
    {
      "id": "ecr-credentials",
      "type": "secretText",
      "description": "AWS ECR registry token or password",
      "secretEnv": "ECR_CREDENTIALS"
    },
    {
      "id": "aws-creds",
      "type": "usernamePassword",
      "description": "AWS access key and secret key",
      "usernameEnv": "AWS_ACCESS_KEY_ID",
      "passwordEnv": "AWS_SECRET_ACCESS_KEY"
    },
    {
      "id": "aws_creds",
      "type": "usernamePassword",
      "description": "AWS access key and secret key alternate ID",
      "usernameEnv": "AWS_CREDS_ACCESS_KEY_ID",
      "passwordEnv": "AWS_CREDS_SECRET_ACCESS_KEY"
    },
    {
      "id": "aws-cicd",
      "type": "usernamePassword",
      "description": "AWS CI/CD access credentials",
      "usernameEnv": "AWS_CICD_ACCESS_KEY_ID",
      "passwordEnv": "AWS_CICD_SECRET_ACCESS_KEY"
    },
    {
      "id": "aws-default-region",
      "type": "secretText",
      "description": "AWS default region",
      "secretEnv": "AWS_DEFAULT_REGION"
    },
    {
      "id": "aws-account-id",
      "type": "secretText",
      "description": "AWS account ID",
      "secretEnv": "AWS_ACCOUNT_ID"
    },
    {
      "id": "ecr-registry-url",
      "type": "secretText",
      "description": "AWS ECR registry URL",
      "secretEnv": "ECR_REGISTRY"
    },
    {
      "id": "asm-cicd",
      "type": "usernamePassword",
      "description": "ASM CI/CD credentials",
      "usernameEnv": "ASM_CICD_USERNAME",
      "passwordEnv": "ASM_CICD_PASSWORD"
    },
    {
      "id": "github-cicd",
      "type": "usernamePassword",
      "description": "GitHub CI/CD username and token",
      "usernameEnv": "GITHUB_CICD_USERNAME",
      "passwordEnv": "GITHUB_CICD_TOKEN"
    },
    {
      "id": "githubcred",
      "type": "usernamePassword",
      "description": "GitHub credentials",
      "usernameEnv": "GITHUB_USERNAME",
      "passwordEnv": "GITHUB_TOKEN"
    },
    {
      "id": "git-credentials",
      "type": "usernamePassword",
      "description": "Git credentials",
      "usernameEnv": "GIT_USERNAME",
      "passwordEnv": "GIT_TOKEN"
    },
    {
      "id": "redberyl-tech",
      "type": "usernamePassword",
      "description": "RedBeryl Tech Git credentials",
      "usernameEnv": "REDBERYL_TECH_USERNAME",
      "passwordEnv": "REDBERYL_TECH_TOKEN"
    },
    {
      "id": "grafana-token",
      "type": "secretText",
      "description": "Grafana API token",
      "secretEnv": "GRAFANA_TOKEN"
    },
    {
      "id": "grafana-service-token",
      "type": "secretText",
      "description": "Grafana service account token",
      "secretEnv": "GRAFANA_SERVICE_TOKEN"
    },
    {
      "id": "sonar-creds",
      "type": "secretText",
      "description": "Sonar token",
      "secretEnv": "SONAR_TOKEN"
    },
    {
      "id": "sonar_creds",
      "type": "secretText",
      "description": "Sonar token alternate ID",
      "secretEnv": "SONAR_TOKEN_ALT"
    },
    {
      "id": "sonar1-creds",
      "type": "secretText",
      "description": "Sonar 1 token",
      "secretEnv": "SONAR1_TOKEN"
    },
    {
      "id": "sonar2-creds",
      "type": "secretText",
      "description": "Sonar 2 token",
      "secretEnv": "SONAR2_TOKEN"
    },
    {
      "id": "sonar-admin-creds",
      "type": "usernamePassword",
      "description": "Sonar admin credentials",
      "usernameEnv": "SONAR_ADMIN_USERNAME",
      "passwordEnv": "SONAR_ADMIN_PASSWORD"
    },
    {
      "id": "node_id",
      "type": "secretText",
      "description": "Node ID",
      "secretEnv": "NODE_ID"
    },
    {
      "id": "node-ssh",
      "type": "sshPrivateKey",
      "description": "Node SSH private key",
      "usernameEnv": "NODE_SSH_USERNAME",
      "privateKeyBase64Env": "NODE_SSH_PRIVATE_KEY_B64",
      "passphraseEnv": "NODE_SSH_PASSPHRASE"
    },
    {
      "id": "dev-remote-ssh",
      "type": "sshPrivateKey",
      "description": "DEV remote server SSH private key",
      "usernameEnv": "DEV_REMOTE_SSH_USERNAME",
      "privateKeyBase64Env": "DEV_REMOTE_SSH_PRIVATE_KEY_B64",
      "passphraseEnv": "DEV_REMOTE_SSH_PASSPHRASE"
    },
    {
      "id": "qa-remote-ssh",
      "type": "sshPrivateKey",
      "description": "QA remote server SSH private key",
      "usernameEnv": "QA_REMOTE_SSH_USERNAME",
      "privateKeyBase64Env": "QA_REMOTE_SSH_PRIVATE_KEY_B64",
      "passphraseEnv": "QA_REMOTE_SSH_PASSPHRASE"
    },
    {
      "id": "support-ssh",
      "type": "sshPrivateKey",
      "description": "Support server SSH private key",
      "usernameEnv": "SUPPORT_SSH_USERNAME",
      "privateKeyBase64Env": "SUPPORT_SSH_PRIVATE_KEY_B64",
      "passphraseEnv": "SUPPORT_SSH_PASSPHRASE"
    }
  ]
}
