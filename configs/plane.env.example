# Plane env example. Put real values in configs/plane.env. Do not commit real secrets.
# Public/browser URL uses SERVER_IP or domain.
WEB_URL=http://SERVER_IP:8001
CORS_ALLOWED_ORIGINS=http://SERVER_IP:8001

# Internal URLs use Docker service names.
POSTGRES_DB=plane
POSTGRES_USER=plane
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_HOST=plane-db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://plane:CHANGE_ME@plane-db:5432/plane
REDIS_HOST=plane-redis
REDIS_PORT=6379
REDIS_URL=redis://plane-redis:6379
RABBITMQ_DEFAULT_USER=plane
RABBITMQ_DEFAULT_PASS=CHANGE_ME
AMQP_HOST=plane-mq
AMQP_PORT=5672
AMQP_USER=plane
AMQP_PASSWORD=CHANGE_ME
AMQP_URL=amqp://plane:CHANGE_ME@plane-mq:5672/
MINIO_ROOT_USER=planeadmin
MINIO_ROOT_PASSWORD=CHANGE_ME
AWS_ACCESS_KEY_ID=planeadmin
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_S3_ENDPOINT_URL=http://plane-minio:9000
AWS_S3_BUCKET_NAME=uploads
AWS_REGION=us-east-1
SECRET_KEY=CHANGE_ME
DEBUG=0
